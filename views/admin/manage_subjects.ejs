<!DOCTYPE html>
<html>
    <head>
        <title>Manage Subjects</title>
        <link rel="stylesheet" href="/style.css">
    </head>
    <body>
        <%- include('../partials/admin_sidebar') %>

        <div class="main-content">
            <div class="title">
                <h1>Manage Subjects</h1>
            </div>
            <button type="button" class="add-subject" onclick="window.location.href='/admin/subjects/add'">Add Subject</button>

            <div class="add-student-table">
                <table>
                    <thead>
                        <tr>
                            <th>Code</th>
                            <th>Subject Name</th>
                            <th>Credits</th>
                            <th>Faculty Assigned</th>
                            <th colspan="2">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% subjects.forEach(function(subject) { %>
                        <tr>
                            <td style="font-weight: bold;"><%= subject.code
                                %></td>
                            <td><%= subject.name %></td>
                            <td><%= subject.credits %></td>
                            <td>
                                <% if (subject.faculty_name) { %>
                                <span class="faculty-tag"><%=
                                    subject.faculty_name %></span>
                                <% } else { %>
                                <span class="unassigned">Not Assigned</span>
                                <% } %>
                            </td>

                            <td>
                                <button class="edit-subject"
                                    onclick="window.location.href='/admin/subjects/edit/<%= subject.id %>'">Edit</button>
                            </td>

                            <td>
                                <form
                                    action="/admin/subjects/<%= subject.id %>/delete"
                                    method="POST"
                                    onsubmit="return confirm('Delete this subject? This might affect student registrations.');">
                                    <button type="submit"
                                        class="delete-btn">Delete</button>
                                </form>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>

        <script src="/script.js"></script>
    </body>
</html>
