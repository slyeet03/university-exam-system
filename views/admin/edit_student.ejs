<!DOCTYPE html>
<html>
<head>
    <title>Edit Student</title>
    <link rel="stylesheet" href="/style.css">
</head>
  <body>
    <%- include('../partials/admin_sidebar') %>
    <div class="main-content">
          <div class="title">
      <h1>Edit Student</h1>
    </div>
      <div class="create-user-container">
        <% students.forEach(function(student) { %> 
  <form action="/admin/student/<%= student.id %>/edit" method="POST" class="create-user-form">
    
    <div class="form-group">
  <label for="name">Name:</label>
  <input type="text" id="name" name="name" value="<%= student.name %>">
</div>

<div class="form-group">
  <label for="email">Email:</label>
  <input type="email" id="email" name="email" value="<%= student.email %>">
</div>

<div class="form-group">
  <label for="roll">Roll:</label>
  <input type="text" id="roll" name="roll" value="<%= student.registration_no %>">
</div>

<div class="form-group">
  <label for="course">Course:</label>
  <input type="text" id="course" name="course" value="<%= student.department %>">
</div>

<div class="form-group">
  <label for="semester">Semester:</label>
  <input type="number" id="semester" name="semester" value="<%= student.semester %>">
</div>


    <div class="form-actions">
      <button type="submit">[ Update Student ]</button>
    </div>

  </form>
        <% }); %>
</div>
    </div>
  <script src="/script.js"></script>
  </body>
</html>
