<!DOCTYPE html>
<html>
    <head>
        <title>Manage Faculty</title>
        <link rel="stylesheet" href="/style.css">
    </head>
    <body>
        <%- include('../partials/admin_sidebar') %>

        <div class="main-content">
            <div class="title">
                <h1>Manage Faculty</h1>
            </div>

            <button type="button" class="add-faculty">Add Faculty</button>

            <div class="faculty-table">
                <table>
                    <thead>
                        <tr>
                            <th>Faculty ID</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Department</th>
                            <th>Subject</th>
                            <th colspan="2">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% facultyList.forEach(function(faculty) { %>
                        <tr>
                            <td><%= faculty.id || 'N/A' %></td>
                            <td><%= faculty.name %></td>
                            <td><%= faculty.email %></td>
                            <td><%= faculty.department || 'General' %></td>
                            <td><%= faculty.subjects || 'N/A' %></td>

                            <td>
                                <button class="edit-faculty"
                                    data-id="<%= faculty.id %>">Edit</button>
                            </td>

                            <td>
                                <form
                                    action="/admin/faculty/<%= faculty.id %>/delete"
                                    method="POST"
                                    onsubmit="return confirm('Delete this faculty member?');">
                                    <button type="submit"
                                        class="delete-btn">Delete</button>
                                </form>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>

        <script src="/script.js"></script>
    </body>
</html>
