<!DOCTYPE html>
<html>
<head>
    <title>Exams Overview</title>
    <link rel="stylesheet" href="/style.css">
</head>
  <body>
    <%- include('../partials/admin_sidebar') %>
    <div class="main-content">
      <div class="title">
      <h1>Exams Overview</h1>
    </div>
        <div class="exam-table">
      <table>
        <tr>
        <th>Subject</th>
        <th>Exam Type</th>
        <th>Date</th>
        <th>Faculty</th>
        <th>Students</th>
        </tr>
        <% exams.forEach(function(exam){ %>
        <tr>
        <td><%= exam.name %></td>
        <td><%= exam.exam_type %></td>
        <td><%= exam.exam_date %></td>
        <td><%= exam.faculty %></td>
        <td><%= exam.studentCount %></td>
        </tr>
        <% }) %>
      </table>
    </div>

    </div>
      </body>
</html>
